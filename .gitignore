# Documentation Build
docs/_build/
docs/build/

# Keep Important Examples
!examples/
!examples/*.py
!examples/*.md

# Keep Configuration Templates
!config/*.yaml.example
!config/*.json.example

# Keep Documentation
!docs/*.md
!docs/*.rst

# Keep Requirements
!requirements*.txt

# Keep README and Setup Files
!README.md
!setup.py
!setup.cfg
!pyproject.toml

# Keep License
!LICENSE
!LICENSE.txt
!LICENSE.md

# Keep GitHub Files
!.github/
!.github/**

# Keep Scripts
!scripts/
!scripts/*.py
!scripts/*.sh

# Exception: Keep some example outputs for documentation
!docs/images/
!docs/images/*.png
!docs/images/*.jpg

# Exception: Keep small test data files
!data/test/
!data/examples/
data/test/*.db
data/examples/*.db
